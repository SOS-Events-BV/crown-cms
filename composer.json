{
    "name": "sos-events-bv/crown-cms",
    "description": "CMS Panel plugin for websites of SOS Events BV.",
    "keywords": [
        "SOS-Events-BV",
        "laravel",
        "filamentphp",
        "filament",
        "filament-plugin",
        "crown-cms"
    ],
    "homepage": "https://github.com/sos-events-bv/crown-cms",
    "support": {
        "issues": "https://github.com/sos-events-bv/crown-cms/issues",
        "source": "https://github.com/sos-events-bv/crown-cms"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "SOS Events BV",
            "email": "ict@sos-events.nl",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "require-dev": {
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.7|^4.0",
        "pestphp/pest-plugin-arch": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "pestphp/pest-plugin-livewire": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "SOSEventsBV\\CrownCms\\": "src/",
            "SOSEventsBV\\CrownCms\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SOSEventsBV\\CrownCms\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "lint": "pint",
        "test": "pest",
        "test:lint": "pint --test"
    },
    "extra": {
        "laravel": {
            "providers": [
                "SOSEventsBV\\CrownCms\\CrownCmsServiceProvider"
            ],
            "aliases": {
                "CrownCms": "SOSEventsBV\\CrownCms\\Facades\\CrownCms"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}